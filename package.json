{
  "name": "bpj-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "check:conflicts": "node scripts/check-conflicts.mjs",
    "prebuild": "npm run check:conflicts",
    "build": "vite build",
    "preview": "vite preview",
    "railway:build": "npm install --include=dev && npm ci --prefix server --omit=dev && npm run build",
    "railway:start": "npm start --prefix server"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^3.8.1",
    "@stripe/stripe-js": "^7.7.0",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.534.0",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.7.1",
    "swiper": "^11.2.10"
  }
}
