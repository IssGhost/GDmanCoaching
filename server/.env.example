PORT=5001
NODE_ENV=development

# Required for any local API run. To avoid running MongoDB locally, paste your Railway MongoDB connection string here,
# or skip the local API and set frontend VITE_API_URL=https://YOUR-RAILWAY-APP.up.railway.app/api.
# The server also accepts MONGODB_URI, MONGO_URL, or DATABASE_URL if your host provides one of those names.
MONGO_URI=mongodb://127.0.0.1:27017/picklepro_dev

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional production integrations. If missing, the app runs in demo mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=
