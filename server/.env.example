PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/good_coaching_dev
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Stripe test mode setup:
# 1. Create a Stripe account.
# 2. Use test mode keys first: sk_test_...
# 3. Create a webhook endpoint for https://YOUR-DOMAIN.com/api/payments/webhook
# 4. Subscribe at least to checkout.session.completed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Safe testing fallback. Keep false/blank for live.
# PAYMENTS_MODE=stripe uses real Stripe test/live keys.
# PAYMENTS_MODE=mock completes orders without moving money.
PAYMENTS_MODE=stripe
ENABLE_MOCK_PAYMENTS=false

# Cloudflare Stream video upload setup:
# Cloudflare Free DNS/SSL is separate from Stream. Stream has its own billing.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=

# Safe testing fallback. Keep false/blank for live.
# VIDEO_UPLOADS_MODE=mock lets the upload flow complete without Cloudflare Stream.
VIDEO_UPLOADS_MODE=cloudflare
ENABLE_MOCK_UPLOADS=false