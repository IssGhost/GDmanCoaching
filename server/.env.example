PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/good_coaching_dev
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Safe testing fallback. Keep false/blank for live.
# PAYMENTS_MODE=stripe uses real Stripe test/live keys.
# PAYMENTS_MODE=mock completes orders without moving money.
PAYMENTS_MODE=stripe
ENABLE_MOCK_PAYMENTS=false

# Cloudflare Stream video upload setup:
# Cloudflare Free DNS/SSL is separate from Stream. Stream has its own billing.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_TOKEN=
SUPPORT_EMAIL=blake@goodmanpickleball.com
EMAIL_FROM="GOOD Coaching <support@goodmanpickleball.com>"
RESEND_API_KEY=
SENDGRID_API_KEY=
